function parseDb02Body(blocks) {
  const tableBlock = blocks.find(b => b.type === "table");
  if (!tableBlock) return null;
  const rows = tableBlock.children || [];
  if (rows.length < 2) return null;
  const headerCells = rows[0].table_row?.cells || [];
  let db02ColIdx = 2;
  headerCells.forEach((cell, idx) => {
    const t = (cell[0]?.plain_text || "").trim().toLowerCase();
    if (t === "db_02" || t === "db02" || t === "値" || t === "value") db02ColIdx = idx;
  });
  let itemColIdx = 1;
  headerCells.forEach((cell, idx) => {
    const t = (cell[0]?.plain_text || "").trim().toLowerCase();
    if (t === "item name" || t === "item" || t === "項目") itemColIdx = idx;
  });
  const raw = {};
  rows.slice(1).forEach(row => {
    const cells = row.table_row?.cells || [];
    const itemName = (cells[itemColIdx]?.[0]?.plain_text || "").trim();
    const db02Val  = (cells[db02ColIdx]?.[0]?.plain_text || "").trim();
    if (itemName && db02Val) raw[itemName] = db02Val;
  });
  const result = {};
  for (const [itemName, def] of Object.entries(DB02_KEY_MAP)) {
    const rawVal = raw[itemName];
    if (!rawVal) continue;
    result[def.key] = convertDb02Val(rawVal, def.type, result);
  }
  for (const [itemName, def] of Object.entries(DB02_KEY_MAP)) {
    if (!def.type.endsWith("_or_same") && !def.type.endsWith("_same")) continue;
    const v = result[def.key];
    if (v === "C_項目と同じ" || v === "same") {
      const cKey = def.key.replace(/^f_/, "");
      result[def.key] = result[cKey] ?? v;
    }
  }
  return result;
}

function convertDb02Val(v, type, ctx) {
  if (!v) return null;
  const s = v.trim();
  if (type === "pct" || type === "pct_or_same") {
    if (s === "C_項目と同じ") return "C_項目と同じ";
    const m = s.match(/(\d+(?:\.\d+)?)\s*%/);
    if (m) return parseFloat(m[1]) / 100;
    const n = parseFloat(s);
    if (!isNaN(n)) return n > 1 ? n / 100 : n;
    return null;
  }
  if (type === "num" || type === "num_dollar") {
    const m = s.match(/\$?([\d,]+(?:\.\d+)?)/);
    if (m) return parseFloat(m[1].replace(/,/g, ""));
    return null;
  }
  if (type === "rule" || type === "rule_or_same") {
    if (s === "C_項目と同じ") return "C_項目と同じ";
    if (["有", "無", "※有", "記載なし"].includes(s)) return s;
    const l = s.toLowerCase();
    if (l === "yes" || l === "required") return "有";
    if (l === "no" || l === "not required" || l === "none") return "無";
    if (l.startsWith("※") || l.includes("conditional") || l.includes("optional")) return "※有";
    if (l.includes("not mentioned") || l.includes("n/a")) return "記載なし";
    if (s.includes("有") || s.includes("無")) return s.slice(0, 3);
    return "記載なし";
  }
  if (type === "ddtype" || type === "ddtype_or_same") {
    if (s === "C_項目と同じ") return "C_項目と同じ";
    const norm = DDTYPE_MAP[s.toLowerCase()];
    if (norm) return norm;
    const l = s.toLowerCase();
    for (const [k, v2] of Object.entries(DDTYPE_MAP)) { if (l.includes(k)) return v2; }
    return s;
  }
  if (type === "str" || type === "str_or_same") {
    if (s === "C_項目と同じ") return "C_項目と同じ";
    return s;
  }
  if (type === "step") return classifyStep(s);
  if (type === "sizes") {
    return s.split(/[,/、]/).map(x => {
      const m = x.trim().replace(/\$/g, "").replace(/,/g, "");
      const n = parseFloat(m);
      if (isNaN(n)) return null;
      if (n >= 1000000) return (n/1000000).toFixed(0).replace(/\.0$/,"") + "M";
      if (n >= 1000)    return (n/1000).toFixed(n%1000===0?0:1).replace(/\.0$/,"") + "K";
      return String(n);
    }).filter(Boolean);
  }
  if (type === "price_list") {
    return s.split("/").map(part => {
      const m = part.trim().match(/(\S+)\s*:\s*\$?([\d,]+(?:\.\d+)?)/);
      if (!m) return null;
      return { size: m[1].trim(), price: parseFloat(m[2].replace(/,/g, "")) };
    }).filter(Boolean);
  }
  return s;
}

async function fetchDb02Bodies(env, db02Pages) {
  const hit = await kvGet(env, KV_KEYS.DB02_BODIES);
  if (hit) return hit;
  const key = env.NOTION_API_KEY;
  const BATCH_SIZE = 5;
  const map = {};
  for (let i = 0; i < db02Pages.length; i += BATCH_SIZE) {
    const batch = db02Pages.slice(i, i + BATCH_SIZE);
    const results = await Promise.all(
      batch.map(async p => {
        try {
          const blocks = await getChildBlocks(key, p.id);
          const parsed = parseDb02Body(blocks);
          return { id: p.id, data: parsed };
        } catch (e) { return { id: p.id, data: null }; }
      })
    );
    results.forEach(r => { map[r.id] = r.data; });
  }
  await kvPut(env, KV_KEYS.DB02_BODIES, map);
  return map;
}

