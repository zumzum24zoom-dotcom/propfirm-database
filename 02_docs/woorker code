// ★ v21: 攻略記事テーブルパース関連関数
async function fetchPage(key, pageId) {
  const r = await fetch(`https://api.notion.com/v1/pages/${pageId}`, {
    headers: { Authorization: `Bearer ${key}`, "Notion-Version": "2022-06-28" },
  });
  if (!r.ok) return null;
  return await r.json();
}

function extractDays(cellText) {
  if (!cellText) return null;
  const m = cellText.match(/(\d+)\s*日/);
  return m ? parseInt(m[1]) : null;
}

function parseTimelineTable(blocks) {
  const tables = blocks.filter(b => b.type === "table");
  if (tables.length === 0) return null;
  const lastTable = tables[tables.length - 1];
  const rows = lastTable.children || [];
  if (rows.length < 2) return null;

  const headerCells = rows[0].table_row?.cells || [];
  let planIdx = -1, qualifyIdx = -1, payoutIdx = -1, totalIdx = -1;
  headerCells.forEach((cell, idx) => {
    const t = (cell[0]?.plain_text || "").replace(/\*/g, "").trim();
    if (t.includes("プラン名")) planIdx = idx;
    if (t.includes("最短合格")) qualifyIdx = idx;
    if (t.includes("最速出金")) payoutIdx = idx;
    if (t.includes("トータル")) totalIdx = idx;
  });
  if (planIdx < 0 || qualifyIdx < 0 || payoutIdx < 0) return null;

  const result = [];
  rows.slice(1).forEach(row => {
    const cells = row.table_row?.cells || [];
    const planName = (cells[planIdx]?.[0]?.plain_text || "").replace(/\*/g, "").trim();
    const qualifyDays = extractDays(cells[qualifyIdx]?.[0]?.plain_text || "");
    const payoutDays = extractDays(cells[payoutIdx]?.[0]?.plain_text || "");
    const totalDays = totalIdx >= 0 ? extractDays(cells[totalIdx]?.[0]?.plain_text || "") : null;
    if (planName && (qualifyDays !== null || payoutDays !== null)) {
      result.push({ planName, qualifyDays, payoutDays, totalDays });
    }
  });
  return result.length > 0 ? result : null;
}

function matchPlanName(db02Name, articlePlanName) {
  if (!db02Name || !articlePlanName) return false;
  if (db02Name === articlePlanName) return true;
  const stripped = db02Name.replace(/^.+?\s*[-–—]\s*/, "").trim();
  if (stripped === articlePlanName) return true;
  if (articlePlanName.includes(stripped)) return true;
  if (stripped.includes(articlePlanName)) return true;
  return false;
}

async function updateMinDaysFromArticle(env, db02Page, dbp02PageId) {
  const key = env.NOTION_API_KEY;
  const fail = (reason) => ({ success: false, reason, plan: "", matched_to: "", min_qualify_days: null, min_payout_days: null });

  const db01RelInDb02 = db02Page.properties["DB01"]?.relation;
  if (!db01RelInDb02 || db01RelInDb02.length === 0) {
    return fail("DB_01 relation not found on DB_02");
  }
  const db01Id = db01RelInDb02[0].id;

  const db01Page = await fetchPage(key, db01Id);
  const dbp01Rel = db01Page?.properties?.["DBP_01データ反映"]?.relation;
  const dbp01Id = dbp01Rel && dbp01Rel.length > 0 ? dbp01Rel[0].id : null;
  if (!dbp01Id) {
    return fail("DBP_01 not found for this Firm");
  }

  const db06Pages = await queryAll(key, DB_06_ID);
  const articlePage = db06Pages.find(p => {
    const rel = p.properties["DBP_01"]?.relation;
    return rel && rel.some(r => r.id === dbp01Id);
  });
  if (!articlePage) {
    return fail("攻略記事 not found for this Firm");
  }

  const articleBlocks = await getChildBlocks(key, articlePage.id);
  const timelineData = parseTimelineTable(articleBlocks);
  if (!timelineData) {
    return fail("最速出金スケジュールテーブル not found in article");
  }

  const challengeName = db02Page.properties["チャレンジ名"]?.title?.[0]?.plain_text || "";
  const matched = timelineData.find(row => matchPlanName(challengeName, row.planName));
  if (!matched) {
    return fail(`プラン名マッチ失敗: "${challengeName}" vs [${timelineData.map(r => r.planName).join(", ")}]`);
  }

  const updateProps = {};
  if (matched.qualifyDays !== null) updateProps["最短合格"] = { number: matched.qualifyDays };
  if (matched.payoutDays !== null) updateProps["最速出金"] = { number: matched.payoutDays };
  if (Object.keys(updateProps).length === 0) {
    return fail("No values to update");
  }

  const updateRes = await fetch(`https://api.notion.com/v1/pages/${dbp02PageId}`, {
    method: "PATCH",
    headers: { Authorization: `Bearer ${key}`, "Content-Type": "application/json", "Notion-Version": "2022-06-28" },
    body: JSON.stringify({ properties: updateProps }),
  });
  if (!updateRes.ok) {
    return fail(`Notion update failed: ${await updateRes.text()}`);
  }

  return {
    success: true,
    reason: "",
    plan: challengeName,
    matched_to: matched.planName,
    min_qualify_days: matched.qualifyDays,
    min_payout_days: matched.payoutDays,
  };
}
