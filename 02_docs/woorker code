async function kvGet(env, key) {
  if (!env.PEF_CACHE) return null;
  try { return await env.PEF_CACHE.get(key, "json"); } catch (e) { return null; }
}
async function kvPut(env, key, value) {
  if (!env.PEF_CACHE) return;
  try { await env.PEF_CACHE.put(key, JSON.stringify(value), { expirationTtl: KV_TTL }); } catch (e) { console.error("KV put failed:", key, e.message); }
}
async function kvDelete(env, key) {
  if (!env.PEF_CACHE) return;
  try { await env.PEF_CACHE.delete(key); } catch (e) {}
}

