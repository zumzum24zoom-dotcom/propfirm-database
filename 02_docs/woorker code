export default {
  async fetch(request, env) {
    if (request.method === "OPTIONS") return new Response(null, { headers: CORS });
    const url = new URL(request.url);
    const p   = url.pathname;
    if (request.method === "GET"  && p === "/api/scores")       return handleScores(env);
    if (request.method === "GET"  && p === "/api/chart")        return handleChart(env, url.searchParams.get("id"));
    if (request.method === "GET"  && p === "/api/rules")        return handleRules(env, url.searchParams.get("id"));
    if (request.method === "GET"  && p === "/api/price-cta")    return handlePriceCta(env, url.searchParams.get("id"));
    if (request.method === "GET"  && p === "/api/coupons")      return handleCoupons(env);
    if (request.method === "GET"  && p === "/api/firms")        return handleFirms(env);
    if (request.method === "GET"  && p === "/api/prices")       return handlePrices(env);
    if (request.method === "GET"  && p === "/api/firms-list")   return handleFirmsList(env);
    if (request.method === "GET"  && p === "/api/plans")        return handlePlans(env);
    if (request.method === "POST" && p === "/api/rules-write")  return handleRulesWrite(env, url.searchParams.get("id"));
    if (request.method === "POST" && p === "/api/expand_plan")  return handleExpandPlan(env, url.searchParams.get("id"));
    if (request.method === "POST" && p === "/api/llm")          return handleLLM(request, env);
    if (request.method === "GET" && p === "/admin/prewarm") {
      const auth = url.searchParams.get("key");
      const expected = (env.NOTION_API_KEY || "").slice(-4);
      if (!auth || auth !== expected) return new Response(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { ...CORS, "Content-Type": "application/json" } });
      const t0 = Date.now();
      try { await prewarmCaches(env); return jsonRes({ message: "Prewarm complete", elapsed_ms: Date.now() - t0, timestamp: now() }); } catch (e) { return errRes(e); }
    }
    const body = await request.json();
    const res = await fetch("https://api.notion.com/v1/pages", { method: "POST", headers: { Authorization: `Bearer ${env.NOTION_API_KEY}`, "Content-Type": "application/json", "Notion-Version": "2022-06-28" }, body: JSON.stringify(body) });
    const data = await res.json();
    return new Response(JSON.stringify(data), { headers: { "Content-Type": "application/json", ...CORS } });
  },
  async scheduled(event, env, ctx) { ctx.waitUntil(prewarmCaches(env)); },
};

// ── LLMプロキシ：ブラウザはキーを持たず、ここでenv.ANTHROPIC_KEYを付けてAnthropicに中継 ──
async function handleLLM(request, env) {
  try {
    if (!env.ANTHROPIC_KEY) {
      return new Response(JSON.stringify({ error: "ANTHROPIC_KEY not configured on Worker" }), { status: 500, headers: { ...CORS, "Content-Type": "application/json" } });
    }
    const body = await request.json();
    const resp = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": env.ANTHROPIC_KEY,
        "anthropic-version": "2023-06-01",
      },
      body: JSON.stringify(body),
    });
    const text = await resp.text();
    // Anthropicのstatus・本文をそのまま透過（400の理由もブラウザで読める）
    return new Response(text, { status: resp.status, headers: { ...CORS, "Content-Type": "application/json" } });
  } catch (e) {
    return new Response(JSON.stringify({ error: e.message }), { status: 500, headers: { ...CORS, "Content-Type": "application/json" } });
  }
}

async function prewarmCaches(env) {
  try {
    await kvDelete(env,KV_KEYS.TABLES);const tables=await fetchAllTables(env);
    await kvDelete(env,KV_KEYS.DB02_BODIES);await fetchDb02Bodies(env,tables.db02Pages);
    await kvDelete(env,KV_KEYS.DB10);await fetchDb10Pages(env);
    await kvDelete(env,KV_KEYS.SCORES);await kvDelete(env,KV_KEYS.PLANS);
    await handleScores(env);await handlePlans(env);
  } catch(e){console.error("prewarmCaches error:",e.message);}
}

async function handleExpandPlan(env, planId) {
