    const rowsToCreate=[];
    if(priceList.length>0){for(const{size,price}of priceList){const k=`${size}_USD`;if(existingRels.has(k))continue;rowsToCreate.push({size,currency:"USD",price});}}else{for(const size of sizes){const k=`${size}_USD`;if(existingRels.has(k))continue;rowsToCreate.push({size,currency:"USD",price:null});}}
    if(rowsToCreate.length===0)return jsonRes({message:"All rows already exist",created:0});
    const dbp02IdHyphened=dbp02Page.id;
    const created=await Promise.all(rowsToCreate.map(async({size,currency,price})=>{const db02Pages=await queryAll(key,DB_02_ID);const db02Page=db02Pages.find(p=>p.id===db02Id);const planName=db02Page?.properties["チャレンジ名"]?.title?.[0]?.plain_text||db02Id;const title=`${planName} (${size} ${currency})`;const body={parent:{database_id:DB_10_ID},properties:{"価格アイテム":{title:[{text:{content:title}}]},"DBP_02":{relation:[{id:dbp02IdHyphened}]},"サイズ":{select:{name:size}},"通貨":{select:{name:currency}},...(price!==null?{"定価":{number:price}}:{})}};const r=await fetch("https://api.notion.com/v1/pages",{method:"POST",headers:{Authorization:`Bearer ${key}`,"Content-Type":"application/json","Notion-Version":"2022-06-28"},body:JSON.stringify(body)});if(!r.ok)throw new Error(`DB_10 create failed: ${await r.text()}`);return await r.json();}));
    await kvDelete(env,KV_KEYS.DB10);
    return jsonRes({message:"DB_10 rows created",created:created.length,rows:rowsToCreate.map(r=>`${r.size} ${r.currency}${r.price?` $${r.price}`:""}`),dbp02_id:clean,db02_id:db02Id.replace(/-/g,"")});
  }catch(e){return errRes(e);}
}

