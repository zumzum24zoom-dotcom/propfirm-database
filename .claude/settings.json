{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONUTF8=1 python \"${CLAUDE_PROJECT_DIR}/scripts/session-stop.py\"",
            "timeout": 30,
            "statusMessage": "セッション終了処理中（自動コミット・HANDOFF確認）..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONUTF8=1 python \"${CLAUDE_PROJECT_DIR}/scripts/inject-handoff-context.py\"",
            "timeout": 10,
            "statusMessage": "HANDOFF.md読込中..."
          }
        ]
      }
    ]
  }
}
