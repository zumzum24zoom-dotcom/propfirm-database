# 環境変数（APIキー等を含むためコミットしない）
.env
.env.local

# Local Netlify folder
.netlify
public/

# Claude Code ローカル作業領域（skills等・コミット不要）
.claude/

# MCP設定（トークンを含むためコミットしない）
.mcp.json

# スキル（GoogleDrive管理・Git対象外）
.claude/skills/

# 一時ファイル
__pycache__/
*.pyc

# エディタのスワップファイル
*.crswap

# Claudian セッション一時ファイル
.claudian/sessions/

# チャットツリー（トークン含む可能性あり）
99_chat-tree/

# Node modules（一時的に入れた構文チェック用 acorn 等）
01_tools/node_modules/
01_tools/package.json
01_tools/package-lock.json

# Obsidian 設定（undisclosed で管理）
.obsidian/

# 個人計算ツール（非公開: undisclosed リポジトリへ分離済み）
01_tools/**/手取り逆算*.html
01_tools/_archive/手取り逆算*.html

# Playwright MCP runtime artifacts
.playwright-mcp/

# Launcher: クリップボード履歴（個人情報含む可能性あり）
01_tools/launcher/clipboard_data/

# Launcher: エージェントのログファイル
01_tools/launcher/*.log
