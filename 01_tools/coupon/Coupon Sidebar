<div id="pfc-coupon-root"></div>
<script>
(function() {
  const API_URL = '/api/index.json';
  const ROOT_ID = 'pfc-coupon-root';
  const COUPON_PAGE = 'https://www.propfirm-challengers.jp/336660a529e281d0a7f5cb77fce3447b';

  const host = document.getElementById(ROOT_ID);
  if (!host) return;

  const shadow = host.attachShadow({ mode: 'open' });

  const style = document.createElement('style');
  style.textContent = `
    :host { all: initial; font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif; }

    #pfc-sidebar {
      position: fixed;
      right: 0; top: 0; bottom: 0;
      width: 160px;
      background: #131722;
      border-left: 1px solid #2a2e39;
      z-index: 2147483647;
      display: flex;
      flex-direction: column;
      transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
      color: #d1d4dc;
    }
    #pfc-sidebar.hidden { transform: translateX(160px); }

    #pfc-open-btn {
      position: fixed;
      right: 16px; bottom: 20px;
      background: #2962ff; color: #fff;
      padding: 10px 16px; border-radius: 24px;
      font-size: 14px; font-weight: 800;
      border: none; cursor: pointer;
      display: none;
      z-index: 2147483646;
    }

    .pfc-header {
      height: 48px;
      background: #1c202b;
      border-bottom: 1px solid #2a2e39;
      display: flex; align-items: center;
      justify-content: center;
      padding: 0 10px;
      flex-shrink: 0;
    }
    .pfc-live {
      display: flex; align-items: center; gap: 5px;
      font-size: 9px; font-weight: 800;
      color: #fff; letter-spacing: 0.05em;
    }
    .pfc-dot {
      width: 6px; height: 6px;
      background: #ff3b30; border-radius: 50%;
      animation: pfcBlink 1.5s infinite;
    }
    @keyframes pfcBlink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    .pfc-viewport {
      flex: 1; overflow: hidden; position: relative;
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    }

    #pfc-track {
      display: flex; flex-direction: column; width: 100%;
    }
    #pfc-track.running { animation: pfcScroll linear infinite; }
    #pfc-track:hover { animation-play-state: paused; }
    @keyframes pfcScroll { 0%{transform:translateY(0)} 100%{transform:translateY(-50%)} }

    .pfc-card {
      padding: 18px 12px;
      border-bottom: 1px solid #2a2e39;
      display: flex; flex-direction: column;
      align-items: center;
    }
    .pfc-card:hover { background: #1e222d; }

    .pfc-logo {
      width: 40px; height: 40px; border-radius: 50%;
      background: #fff;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 8px;
      overflow: hidden;
    }
    .pfc-logo img { width: 75%; height: 75%; object-fit: contain; }
    .pfc-logo-init { font-size: 18px; font-weight: 900; color: #131722; }

    .pfc-firm {
      font-size: 9px; color: #787b86; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em;
      text-align: center; margin-bottom: 4px;
    }
    .pfc-discount {
      font-size: 18px; font-weight: 900; color: #00c897;
      text-align: center; margin-bottom: 10px; line-height: 1.1;
    }
    .pfc-discount.no-code { margin-bottom: 0; }

    .pfc-code {
      width: 100%; background: rgba(41,98,255,0.15);
      border: 1px dashed #2962ff; border-radius: 4px;
      color: #fff; font-size: 12px; font-weight: 800;
      text-align: center; padding: 8px 4px;
      cursor: pointer; margin-bottom: 8px;
      box-sizing: border-box;
    }
    .pfc-code:hover { background: #2962ff; border-style: solid; }
    .pfc-code.copied { background: #00c897; border-color: #00c897; color: #131722; }

    .pfc-cta {
      display: block; width: 100%;
      background: #2a2e39; color: #d1d4dc;
      text-align: center; text-decoration: none;
      font-size: 9px; font-weight: 800;
      padding: 7px 4px; border-radius: 4px;
      box-sizing: border-box;
    }
    .pfc-cta:hover { background: #fff; color: #131722; }

    .pfc-expiry {
      font-size: 8px; color: #787b86;
      text-align: center; margin-top: 5px;
    }
    .pfc-expiry.soon { color: #ff6b6b; }

    .pfc-footer {
      background: #1c202b;
      border-top: 1px solid #2a2e39;
      display: flex; flex-direction: column;
      gap: 6px;
      padding: 10px;
      flex-shrink: 0;
    }
    .pfc-footer-btn {
      display: block; width: 100%;
      text-align: center; text-decoration: none;
      font-size: 10px; font-weight: 800;
      padding: 8px 4px; border-radius: 4px;
      box-sizing: border-box; cursor: pointer;
      border: none;
    }
    .pfc-btn-page {
      background: #2962ff; color: #fff;
    }
    .pfc-btn-page:hover { background: #1a4fd6; }
    .pfc-btn-close {
      background: #2a2e39; color: #787b86;
    }
    .pfc-btn-close:hover { background: #3a3e49; color: #d1d4dc; }

    @media (max-width: 768px) {
      #pfc-sidebar {
        width: 100%; height: 280px;
        top: auto; bottom: 0;
        border-left: none; border-top: 2px solid #2962ff;
        transform: translateY(0);
      }
      #pfc-sidebar.hidden { transform: translateY(100%); }
      #pfc-track { flex-direction: row; width: max-content; }
      #pfc-track.running { animation: pfcScrollH linear infinite; }
      @keyframes pfcScrollH { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
      .pfc-card { width: 200px; border-bottom: none; border-right: 1px solid #2a2e39; }
      .pfc-viewport { -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); }
      .pfc-footer { flex-direction: row; }
      .pfc-footer-btn { flex: 1; }
    }
  `;

  const container = document.createElement('div');
  container.innerHTML = `
    <div id="pfc-sidebar">
      <div class="pfc-header">
        <div class="pfc-live"><span class="pfc-dot"></span>LIVE DEALS</div>
      </div>
      <div class="pfc-viewport">
        <div id="pfc-track"></div>
      </div>
      <div class="pfc-footer">
        <a href="${COUPON_PAGE}" class="pfc-footer-btn pfc-btn-page">クーポン一覧</a>
        <button id="pfc-close" class="pfc-footer-btn pfc-btn-close">閉じる</button>
      </div>
    </div>
    <button id="pfc-open-btn">🎟️</button>
  `;

  shadow.appendChild(style);
  shadow.appendChild(container);

  const sidebar  = shadow.getElementById('pfc-sidebar');
  const track    = shadow.getElementById('pfc-track');
  const closeBtn = shadow.getElementById('pfc-close');
  const openBtn  = shadow.getElementById('pfc-open-btn');

  closeBtn.onclick = () => { sidebar.classList.add('hidden'); openBtn.style.display = 'block'; };
  openBtn.onclick  = () => { sidebar.classList.remove('hidden'); openBtn.style.display = 'none'; };

  function copyCode(btn, code) {
    navigator.clipboard.writeText(code).then(() => {
      btn.textContent = 'COPIED!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = code; btn.classList.remove('copied'); }, 1800);
    }).catch(() => {
      const el = document.createElement('textarea');
      el.value = code;
      document.body.appendChild(el);
      el.select();
      document.execCommand('copy');
      document.body.removeChild(el);
      btn.textContent = 'COPIED!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = code; btn.classList.remove('copied'); }, 1800);
    });
  }

  function expiryLabel(expiry) {
    if (!expiry) return null;
    const diff = (new Date(expiry) - new Date()) / (1000 * 60 * 60 * 24);
    if (diff < 0) return null;
    return { label: diff <= 1 ? '本日まで' : Math.ceil(diff) + '日後に終了', soon: diff <= 3 };
  }

  function buildCard(coupon) {
    const expInfo = expiryLabel(coupon.expiry);
    if (coupon.expiry && !expInfo) return null;

    const div = document.createElement('div');
    div.className = 'pfc-card';

    const domain = (coupon.site_url || '').replace(/^https?:\/\/(www\.)?/, '').split('/')[0];
    const faviconUrl = domain ? `https://icons.duckduckgo.com/ip3/${domain}.ico` : '';
    const initial = (coupon.firm || '?').charAt(0).toUpperCase();

    const logoHTML = faviconUrl
      ? `<div class="pfc-logo"><img src="${faviconUrl}" onerror="this.style.display='none';this.parentElement.innerHTML='<span class=\'pfc-logo-init\'>${initial}</span>'"></div>`
      : `<div class="pfc-logo"><span class="pfc-logo-init">${initial}</span></div>`;

    const discountHTML = coupon.discount
      ? `<div class="pfc-discount${coupon.coupon_code ? '' : ' no-code'}">${coupon.discount}</div>`
      : '';

    const codeHTML = coupon.coupon_code
      ? `<div class="pfc-code" data-code="${coupon.coupon_code}">${coupon.coupon_code}</div>`
      : '';

    const ctaHTML = coupon.site_url
      ? `<a href="${coupon.site_url}" target="_blank" class="pfc-cta">公式サイトへ</a>`
      : '';

    const expiryHTML = expInfo
      ? `<div class="pfc-expiry${expInfo.soon ? ' soon' : ''}">${expInfo.label}</div>`
      : '';

    div.innerHTML = `${logoHTML}<div class="pfc-firm">${coupon.firm || ''}</div>${discountHTML}${codeHTML}${ctaHTML}${expiryHTML}`;

    if (coupon.coupon_code) {
      div.querySelector('.pfc-code').addEventListener('click', function() {
        copyCode(this, coupon.coupon_code);
      });
    }
    return div;
  }

  async function loadCoupons() {
    try {
      const res  = await fetch(API_URL);
      const data = await res.json();
      const coupons = data.coupons || [];
      if (coupons.length === 0) { sidebar.classList.add('hidden'); return; }

      const cards = coupons.map(buildCard).filter(Boolean);
      if (cards.length === 0) { sidebar.classList.add('hidden'); return; }

      [...cards, ...cards.map(c => c.cloneNode(true))].forEach(c => {
        const codeEl = c.querySelector('.pfc-code');
        if (codeEl) {
          const code = codeEl.dataset.code;
          codeEl.addEventListener('click', function() { copyCode(this, code); });
        }
        track.appendChild(c);
      });

      const duration = Math.max(20, cards.length * 15);
      track.style.animationDuration = duration + 's';
      track.classList.add('running');
    } catch(e) {
      console.warn('PFC Coupon Sidebar: API error', e);
      sidebar.classList.add('hidden');
    }
  }

  loadCoupons();
})();
</script>