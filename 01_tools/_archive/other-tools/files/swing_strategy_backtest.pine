//@version=5
strategy("Swing High/Low Trend Reversal Strategy", overlay=true, 
         default_qty_type=strategy.percent_of_equity, default_qty_value=2, 
         pyramiding=0, max_bars_back=500)

// ===== パラメータ =====
swingLength = input(5, "Swing Detection Period", minval=1)
riskReward = input(1.5, "Risk/Reward Ratio", minval=0.5, maxval=5)
maxDrawdown = input(20, "Max Drawdown %", minval=5, maxval=50)
useTimezone = input(true, "Use Timezone Filter")
tradeDirection = input.string("BOTH", "Trade Direction", options=["UP", "DOWN", "BOTH"])

// ===== グローバル変数 =====
var float lastSwingHigh = na
var float lastSwingHighLow = na
var float lastSwingLow = na
var float lastSwingLowHigh = na

var bool inUptrend = na
var int totalTrades = 0
var int winTrades = 0
var float highestEquity = na
var float drawdown = 0

// ===== 時間フィルタ (東京時間: 09:00 - 15:00 UTC+9) =====
isTokyoSession = useTimezone ? (hour >= 0 and hour <= 6) : true

// ===== Swing High/Low 検出 =====
isSwingHigh = high[swingLength] > ta.highest(high[swingLength + 1], swingLength) and 
              high[swingLength] > ta.highest(high[0], swingLength)

isSwingLow = low[swingLength] < ta.lowest(low[swingLength + 1], swingLength) and 
             low[swingLength] < ta.lowest(low[0], swingLength)

// Swing を記録
if isSwingHigh
    lastSwingHigh := high[swingLength]
    lastSwingHighLow := low[swingLength]
    if na(inUptrend) or inUptrend == false
        inUptrend := true

if isSwingLow
    lastSwingLow := low[swingLength]
    lastSwingLowHigh := high[swingLength]
    if na(inUptrend) or inUptrend == true
        inUptrend := false

// ===== シグナル検出 =====
// 下降転換: 上昇トレンド中に前回安値を下回る
downSignal = inUptrend and not na(lastSwingHighLow) and low < lastSwingHighLow and close < close[1]

// 上昇転換: 下降トレンド中に前回高値を上回る
upSignal = not inUptrend and not na(lastSwingLowHigh) and high > lastSwingLowHigh and close > close[1]

// ===== リスク管理 =====
// 最大ドローダウンチェック
if na(highestEquity)
    highestEquity := strategy.equity
else
    if strategy.equity > highestEquity
        highestEquity := strategy.equity
    
drawdown := ((highestEquity - strategy.equity) / highestEquity) * 100

// ===== エントリー =====
longCondition = upSignal and isTokyoSession and drawdown < maxDrawdown and 
                (tradeDirection == "UP" or tradeDirection == "BOTH") and strategy.opentrades == 0

shortCondition = downSignal and isTokyoSession and drawdown < maxDrawdown and 
                 (tradeDirection == "DOWN" or tradeDirection == "BOTH") and strategy.opentrades == 0

// ロングエントリー
if longCondition
    strategy.entry("Long", strategy.long)
    totalTrades += 1

// ショートエントリー
if shortCondition
    strategy.entry("Short", strategy.short)
    totalTrades += 1

// ===== エグジット =====
// ロングエグジット: 次の下降転換パターンで決定
longExit = inUptrend and downSignal and strategy.position_size > 0

if longExit
    strategy.close("Long")
    if strategy.position_size == 0
        winTrades += 1

// ショートエグジット: 次の上昇転換パターンで決定
shortExit = not inUptrend and upSignal and strategy.position_size < 0

if shortExit
    strategy.close("Short")
    if strategy.position_size == 0
        winTrades += 1

// ===== 描画 =====
// Swing High
plotshape(isSwingHigh, style=shape.triangledown, location=location.abovebar, 
          color=color.red, size=size.small, title="Swing High")

// Swing Low
plotshape(isSwingLow, style=shape.triangleup, location=location.belowbar, 
          color=color.green, size=size.small, title="Swing Low")

// シグナル
plotshape(downSignal, style=shape.arrowdown, location=location.abovebar, 
          color=color.orange, size=size.medium, title="Down Signal")

plotshape(upSignal, style=shape.arrowup, location=location.belowbar, 
          color=color.blue, size=size.medium, title="Up Signal")

// Swing レベル
plot(lastSwingHigh, title="Last Swing High", color=color.new(color.red, 50), linewidth=2)
plot(lastSwingLow, title="Last Swing Low", color=color.new(color.green, 50), linewidth=2)

// ドローダウン警告
hline(maxDrawdown, "Max Drawdown Level", color.red, linestyle=hline.style_dashed)
plot(drawdown, title="Current Drawdown", color=drawdown > maxDrawdown ? color.red : color.green, linewidth=2)

// ===== テーブル表示 =====
var table stats = na

if barstate.islast
    stats := table.new(position.top_right, 3, 5, border_color=color.gray, border_width=1)
    table.cell(stats, 0, 0, "Total Trades:", text_color=color.white)
    table.cell(stats, 1, 0, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(stats, 0, 1, "Win Rate:", text_color=color.white)
    winRate = strategy.closedtrades > 0 ? (strategy.wintrades / strategy.closedtrades * 100) : 0
    table.cell(stats, 1, 1, str.format("{0:.1f}%", winRate), text_color=color.white)
    table.cell(stats, 0, 2, "Profit Factor:", text_color=color.white)
    profitFactor = strategy.grossprofit > 0 ? (strategy.grossprofit / strategy.grossloss) : 0
    table.cell(stats, 1, 2, str.format("{0:.2f}", profitFactor), text_color=color.white)
    table.cell(stats, 0, 3, "Max Drawdown:", text_color=color.white)
    table.cell(stats, 1, 3, str.format("{0:.1f}%", strategy.max_drawdown_percent), text_color=color.white)
    table.cell(stats, 0, 4, "Return:", text_color=color.white)
    table.cell(stats, 1, 4, str.format("{0:.1f}%", strategy.netprofit_percent), text_color=color.white)

// ===== アラート =====
alertcondition(downSignal, title="DOWN Reversal - Sell Signal", message="DOWN trend reversal - Short entry")
alertcondition(upSignal, title="UP Reversal - Buy Signal", message="UP trend reversal - Long entry")
alertcondition(drawdown > maxDrawdown, title="Drawdown Alert", message="Max drawdown exceeded!")
